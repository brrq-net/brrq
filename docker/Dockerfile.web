# =============================================================================
# Brrq Explorer (Next.js) - Multi-stage Docker Build
# =============================================================================
# Stage 1: Install dependencies and build static export
# Stage 2: Serve with nginx
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: Build
# ---------------------------------------------------------------------------
FROM node:22-alpine AS builder

WORKDIR /app

COPY package.json package-lock.json* ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

COPY . .

ENV NEXT_TELEMETRY_DISABLED=1

RUN npx next build

# ---------------------------------------------------------------------------
# Stage 2: Serve static files with nginx
# ---------------------------------------------------------------------------
FROM nginx:1.27-alpine

COPY --from=builder /app/out /usr/share/nginx/html

# SPA fallback: serve index.html for all routes
RUN echo 'server { listen 3000; root /usr/share/nginx/html; location / { try_files $uri $uri.html $uri/ /index.html; } }' > /etc/nginx/conf.d/default.conf

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]
